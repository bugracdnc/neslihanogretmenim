---
// src/pages/index.astro
import Layout from "../layouts/Layout.astro";

// We define our categories here as an array of objects.
// When Neslihan has her actual flower images, you will just add an 'imagePath' property to these objects!
const categories = [
  {
    name: "1. Sınıf İçerikleri",
    slug: "1-sinif",
    color: "bg-pink-200 hover:bg-pink-300",
  },
  {
    name: "2. Sınıf İçerikleri",
    slug: "2-sinif",
    color: "bg-purple-200 hover:bg-purple-300",
  },
  {
    name: "3. Sınıf İçerikleri",
    slug: "3-sinif",
    color: "bg-yellow-200 hover:bg-yellow-300",
  },
  {
    name: "4. Sınıf İçerikleri",
    slug: "4-sinif",
    color: "bg-green-200 hover:bg-green-300",
  },
  {
    name: "Belirli Gün ve Haftalar",
    slug: "belirli-gunler",
    color: "bg-orange-200 hover:bg-orange-300",
  },
  {
    name: "Görsel Sanatlar",
    slug: "gorsel-sanatlar",
    color: "bg-teal-200 hover:bg-teal-300",
  },
];
---

<Layout title="Neslihan Öğretmen | Etkinlik Havuzu">
  <section class="text-center py-12 md:py-20">
    <h1
      class="text-4xl md:text-6xl font-extrabold text-slate-800 tracking-tight mb-6"
    >
      Sınıf İçi <span class="text-blue-500">Etkinlik Havuzu</span>
    </h1>
    <p class="text-lg md:text-xl text-slate-600 max-w-2xl mx-auto px-4">
      Oyunlar, çalışma kağıtları, pano tasarımları ve çok daha fazlası.
      İncelemek istediğiniz kategoriyi seçin!
    </p>
  </section>

  <section class="max-w-5xl mx-auto mt-4 pb-20">
    <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8 px-6">
      {
        categories.map((cat) => (
          <a
            href={`${import.meta.env.BASE_URL}/kategori/${cat.slug}`}
            class={`group relative flex flex-col items-center justify-center p-8 aspect-square rounded-[3rem] shadow-sm transition-all duration-300 transform hover:-translate-y-2 hover:shadow-xl ${cat.color}`}
          >
            <div class="w-24 h-24 mb-6 bg-white/60 rounded-full flex items-center justify-center text-4xl group-hover:scale-110 transition-transform duration-300">
              🌸
            </div>

            <h2 class="text-2xl font-bold text-slate-800 text-center">
              {cat.name}
            </h2>
          </a>
        ))
      }
    </div>
  </section>
</Layout>
