---
// src/pages/kategori/[slug].astro
import { getCollection } from "astro:content";
import Layout from "../../layouts/Layout.astro";
import ActivityList from "../../components/ActivityList.vue";

// Sayfalarımızı ve bu sayfaların hangi "ana etiketi" arayacağını tanımlıyoruz
export function getStaticPaths() {
  return [
    {
      params: { slug: "1-sinif" },
      props: { title: "1. Sınıf İçerikleri", targetTag: "1. Sınıf" },
    },
    {
      params: { slug: "2-sinif" },
      props: { title: "2. Sınıf İçerikleri", targetTag: "2. Sınıf" },
    },
    {
      params: { slug: "3-sinif" },
      props: { title: "3. Sınıf İçerikleri", targetTag: "3. Sınıf" },
    },
    {
      params: { slug: "4-sinif" },
      props: { title: "4. Sınıf İçerikleri", targetTag: "4. Sınıf" },
    },
    {
      params: { slug: "belirli-gunler" },
      props: { title: "Belirli Gün ve Haftalar", targetTag: "Belirli Günler" },
    },
    {
      params: { slug: "gorsel-sanatlar" },
      props: { title: "Görsel Sanatlar", targetTag: "Görsel Sanatlar" },
    },
  ];
}

const { title, targetTag } = Astro.props;

// 1. Tüm etkinlikleri Markdown klasöründen çek
const allActivities = await getCollection("etkinlikler");

// 2. Sadece bu sayfanın ana etiketine (örn: "1. Sınıf") sahip olanları filtrele ve Vue'nun anlayacağı formata çevir
const realActivities = allActivities
  .filter(
    (activity) => activity.data.tags && activity.data.tags.includes(targetTag),
  )
  .map((activity) => ({
    id: activity.id, // Artık id olarak Astro'nun otomatik ürettiği dosya adını (slug) kullanıyoruz
    title: activity.data.title,
    description: activity.data.description,
    tags: activity.data.tags,
    thumbnail: activity.data.thumbnail,
    file: activity.data.file,
  }));
---

<Layout title={`${title} | Neslihan Öğretmen`}>
  <div class="mb-12 text-center mt-12">
    <a
      href={import.meta.env.BASE_URL}
      class="inline-block mb-8 text-pink-500 hover:text-pink-600 font-bold tracking-wide transition-colors"
    >
      &larr; Ana Sayfaya Dön
    </a>
    <h1
      class="text-5xl md:text-6xl font-extrabold text-slate-800 mb-6 tracking-tight"
    >
      {title}
    </h1>
    <p class="text-slate-500 text-xl max-w-2xl mx-auto">
      Bu kategoriye ait tüm materyalleri aşağıdan inceleyebilir ve hızlıca
      indirebilirsiniz.
    </p>
  </div>

  <ActivityList client:load activities={realActivities} />
</Layout>
