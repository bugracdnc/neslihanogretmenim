---
// src/pages/etkinlik/[slug].astro
import { getCollection, render } from "astro:content";
import Layout from "../../layouts/Layout.astro";

// 1. Tell Astro which pages to generate based on our Markdown files
export async function getStaticPaths() {
  const etkinlikler = await getCollection("etkinlikler");

  return etkinlikler.map((entry) => ({
    params: { slug: entry.id }, // entry.id is the filename (e.g., '2026-03-24-test1')
    props: { entry },
  }));
}

// 2. Get the specific data for the current page
const { entry } = Astro.props;
const { Content } = await render(entry); // This magic function compiles the markdown body!
---

<Layout title={`${entry.data.title} | Neslihan Öğretmen`}>
  <article class="max-w-4xl mx-auto px-4 py-12">
    <a
      href="javascript:history.back()"
      class="inline-flex items-center text-pink-500 hover:text-pink-600 font-bold tracking-wide transition-colors mb-10"
    >
      &larr; Geri Dön
    </a>

    <div
      class="bg-white rounded-[3rem] shadow-sm border border-pink-50 overflow-hidden relative"
    >
      <div
        class="absolute -right-20 -top-20 w-64 h-64 bg-gradient-to-br from-amber-50 to-pink-50 rounded-full z-0 opacity-70 pointer-events-none"
      >
      </div>

      <div class="relative z-10 p-8 md:p-12 border-b border-pink-50/50">
        <div class="flex flex-wrap items-center gap-2 mb-6">
          {
            entry.data.tags.map((tag) => (
              <span class="inline-block px-4 py-1.5 bg-pink-100 text-pink-700 text-xs font-extrabold tracking-wide uppercase rounded-full">
                {tag}
              </span>
            ))
          }
        </div>

        <h1
          class="text-4xl md:text-5xl font-extrabold text-slate-800 mb-6 tracking-tight leading-tight"
        >
          {entry.data.title}
        </h1>

        <p class="text-xl text-slate-500 leading-relaxed">
          {entry.data.description}
        </p>
      </div>

      <div class="relative z-10 p-8 md:p-12 flex flex-col md:flex-row gap-10">
        <div class="flex-1 min-w-0">
          {
            entry.data.thumbnail && (
              <div class="mb-10 rounded-3xl overflow-hidden border border-slate-100 shadow-sm">
                <img
                  src={entry.data.thumbnail}
                  alt={entry.data.title}
                  class="w-full h-auto object-cover"
                />
              </div>
            )
          }

          <div
            class="prose prose-pink prose-lg text-slate-600 max-w-none prose-headings:text-slate-800 prose-a:text-pink-500 hover:prose-a:text-pink-600"
          >
            <Content />
          </div>
        </div>

        <div class="md:w-80 shrink-0">
          <div
            class="sticky top-8 bg-slate-50 rounded-3xl p-6 border border-slate-100 text-center"
          >
            <h3 class="text-lg font-bold text-slate-800 mb-2">
              Materyali İndir
            </h3>
            <p class="text-sm text-slate-500 mb-6">
              Bu etkinliğe ait dosyaları bilgisayarınıza veya akıllı tahtaya
              indirebilirsiniz.
            </p>

            {
              entry.data.file ? (
                <a
                  href={entry.data.file}
                  target="_blank"
                  class="block w-full py-4 px-6 bg-gradient-to-r from-pink-400 to-amber-400 hover:from-pink-500 hover:to-amber-500 text-white font-extrabold rounded-2xl transition-all shadow-md hover:shadow-lg transform hover:-translate-y-1"
                >
                  Dosyayı İndir 📥
                </a>
              ) : (
                <div class="py-4 px-6 bg-slate-200 text-slate-500 font-bold rounded-2xl cursor-not-allowed">
                  Ekli Dosya Yok ❌
                </div>
              )
            }
          </div>
        </div>
      </div>
    </div>
  </article>
</Layout>
